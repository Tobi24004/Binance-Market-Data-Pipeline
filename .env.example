# Copy this file to .env and adjust values before running docker-compose up.
# .env itself is gitignored - never commit real credentials.

POSTGRES_DB=binance
POSTGRES_USER=binance
POSTGRES_PASSWORD=change_me

AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me

LOG_LEVEL=INFO

# Set to 1 to also print parsed Spark rows to console (Stage 5 debug step).
SPARK_DEBUG_CONSOLE=0
